# ╔══════════════════════════════════════════════════════════════════╗
# ║  Omni Integrator — Multi-Provider LLM Configuration                ║
# ║  Copy to .env and fill in your API keys                        ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# DESIGN: Each agent role can target a DIFFERENT provider + model.
#         This lets you test combinations like:
#           Orchestrator → OpenRouter / Deepseek-v4-pro
#           Sub-agents   → Nebius    / Deepseek-v4-flash
#           Reviewer     → ZenMux   / Deepseek-v4-pro
#
# PROVIDER VALUES: openrouter | zenmux | nebius
#
# MODEL NAMES vary by provider. Examples:
#   OpenRouter: anthropic/claude-sonnet-4, google/gemini-2.5-flash, openai/gpt-4.1
#   ZenMux:     claude-sonnet-4, gemini-2.5-flash, gpt-4.1
#   Nebius:     anthropic/claude-sonnet-4, google/gemini-2.5-flash

# ─────────────────────────────────────────────────────────────────
# SECTION 1: PROVIDER CREDENTIALS
# Set API key + base URL for each provider you want to use.
# You only need to configure the providers you reference below.
# ─────────────────────────────────────────────────────────────────

# OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ZenMux (load-balanced proxy)
ZENMUX_API_KEY=
ZENMUX_BASE_URL=https://zenmux.ai/api/v1

# Nebius Token Factory
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1

# ─────────────────────────────────────────────────────────────────
# SECTION 2: ROLE → PROVIDER + MODEL ASSIGNMENTS
# Each role gets its own provider and model.
# Change the _PROVIDER to switch where the call goes.
# Change the _MODEL to switch which model handles that role.
# ─────────────────────────────────────────────────────────────────

# ── Orchestrator ─────────────────────────────────────────────────
# Strong model for strategic planning, section analysis, and merging.
ORCHESTRATOR_PROVIDER=zenmux
ORCHESTRATOR_MODEL=deepseek/deepseek-v4-pro

# ── Sub-Agent ────────────────────────────────────────────────────
# Fast model for section-level prompt optimization.
# Gets dispatched per-section, so speed matters more than depth.
SUBAGENT_PROVIDER=zenmux
SUBAGENT_MODEL=deepseek/deepseek-v4-flash

# ── Reviewer ─────────────────────────────────────────────────────
# Strong model for Quality Assurance Validation Gate.
# Must be reliable at structured JSON output.
REVIEWER_PROVIDER=zenmux
REVIEWER_MODEL=deepseek/deepseek-v4-pro

# ── Omni (Video/Audio/Image) ─────────────────────────────────────
# Multimodal model for watching and analyzing video/audio data.
OMNI_PROVIDER=nebius
OMNI_MODEL=nvidia/Nemotron-3-Nano-Omni
YTDLP_BROWSER=brave

# ─────────────────────────────────────────────────────────────────
# SECTION 3: FALLBACK BEHAVIOR
# If a role's primary provider fails, try these in order.
# Set to empty to disable fallback (fail fast).
# ─────────────────────────────────────────────────────────────────

# Comma-separated fallback order (after the role's primary provider)
FALLBACK_PROVIDERS=zenmux,openrouter,nebius

# ─────────────────────────────────────────────────────────────────
# SECTION 4: EXECUTION LIMITS
# ─────────────────────────────────────────────────────────────────

MAX_ITERATIONS=5
MAX_TOKENS_PER_CALL=8192
TIMEOUT_SECONDS=300
PARALLEL_AGENTS=4
