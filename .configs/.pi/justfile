# Pi Coding Agent - Just Recipes
# Usage: just <recipe>
# Or: just -f .pi/justfile <recipe>

set dotenv-load

# Run Pi with no extensions
pi:
    pi

# --- Extensions ---

# Pure distraction-free mode (no footer/status)
pi-pure-focus:
    pi -e .pi/extensions/pure-focus.ts

# Minimal footer with context meter
pi-minimal:
    pi -e .pi/extensions/minimal.ts

# Cross-agent command loading (from .claude, .gemini, etc.)
pi-cross-agent:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/cross-agent.ts

# Purpose gate (blocks prompts until purpose declared)
pi-purpose-gate:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/purpose-gate.ts

# Rich two-line footer with tool tally
pi-tool-counter:
    pi -e .pi/extensions/tool-counter.ts

# Widget above editor showing per-tool call counts
pi-tool-counter-widget:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/tool-counter-widget.ts

# Subagent spawner with live progress widgets
pi-subagent-widget:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/subagent-widget.ts

# Task discipline system (Work Till Done)
pi-tilldone:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/tilldone.ts

# Multi-agent orchestration grid dashboard
pi-agent-team:
    pi -e .pi/extensions/agent-team.ts

# Agent persona switcher via /system command
pi-system-select:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/system-select.ts

# Real-time safety auditing
pi-damage-control:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/damage-control.ts

# Sequential pipeline orchestrator
pi-agent-chain:
    pi -e .pi/extensions/agent-chain.ts

# Meta-agent that builds Pi agents
pi-pi-pi:
    pi -e .pi/extensions/pi-pi.ts

# Session replay timeline
pi-session-replay:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/session-replay.ts

# Theme cycler (Ctrl+X/Q)
pi-theme-cycler:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/theme-cycler.ts

# --- Combinations ---

# "Commander" setup - Minimal + Theme + System Select + Cross Agent
pi-commander:
    pi -e .pi/extensions/minimal.ts -e .pi/extensions/theme-cycler.ts -e .pi/extensions/system-select.ts -e .pi/extensions/cross-agent.ts
