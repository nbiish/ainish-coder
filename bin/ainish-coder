#!/bin/bash
# Main ainish-coder CLI tool
# Comprehensive configuration manager for AI coding assistants

set -euo pipefail

# Ensure we have a minimal PATH for basic commands
# This prevents issues if PATH is corrupted in the calling environment
if [[ ":$PATH:" != *":/usr/bin:"* ]] || [[ ":$PATH:" != *":/bin:"* ]]; then
    export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
fi

# Get script directory, resolving symlinks if necessary
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
DNA_DIR="${SCRIPT_DIR}/../dna"

# Load atoms (core utilities)
source "${DNA_DIR}/atoms/colors.sh"
source "${DNA_DIR}/atoms/paths.sh"
source "${DNA_DIR}/atoms/file_operations.sh"
source "${DNA_DIR}/atoms/validation.sh"
source "${DNA_DIR}/atoms/backup.sh"
source "${DNA_DIR}/atoms/ignore_patterns.sh"

# Load molecules (deployment functions)
source "${DNA_DIR}/molecules/help.sh"
source "${DNA_DIR}/molecules/deploy_commands.sh"
source "${DNA_DIR}/molecules/deploy_agents.sh"

source "${DNA_DIR}/molecules/deploy_critical.sh"
source "${DNA_DIR}/molecules/deploy_gitignore.sh"
# Load ignore file deployment molecules
source "${DNA_DIR}/molecules/deploy_github_actions.sh"
source "${DNA_DIR}/molecules/deploy_local_security.sh"
source "${DNA_DIR}/molecules/deploy_template_agent.sh"
source "${DNA_DIR}/molecules/deploy_skills.sh"
source "${DNA_DIR}/molecules/deploy_unlock.sh"
source "${DNA_DIR}/molecules/deploy_mcp_recipes.sh"
source "${DNA_DIR}/molecules/deploy_scrolls.sh"
source "${DNA_DIR}/molecules/deploy_license.sh"
source "${DNA_DIR}/molecules/deploy_signals.sh"
source "${DNA_DIR}/molecules/deploy_llms_txt.sh"
source "${DNA_DIR}/molecules/cli_interface.sh"

# Main function
main() {
    local command="$1"
    shift

    # Get target directory (default to current directory)
    local target_dir="${1:-$(pwd)}"

    case "$command" in
        --help|-h)
            show_help
            ;;
        --version|-v)
            show_version
            ;;

        # Commands deployment
        --commands)
            if [[ $# -eq 0 ]]; then
                print_error "Missing argument for --commands"
                echo "Usage: ainish-coder --commands {tool}" >&2
                echo "Example: ainish-coder --commands cursor" >&2
                exit 1
            fi
            deploy_commands "$1"
            ;;



        # Core rules deployment
        --rules)
            echo -e "${BRIGHT_BLUE}Deploying Rules System${RESET}"

            if confirm_action "Deploy AGENTS.md standard rules to: $target_dir?" "y"; then
                # Deploy AGENTS.md
                deploy_agents "$target_dir"
            fi

            if confirm_action "Deploy/merge .gitignore configuration to: $target_dir?" "y"; then
                # Deploy .gitignore
                deploy_gitignore "$target_dir"
            fi

            # Offer to deploy pqc-secrets skill
            if confirm_action "Do you want to deploy the post-quantum cryptography secrets skill (pqc-secrets)?" "y"; then
                local skill_dest=""
                if [[ "${AINISH_NON_INTERACTIVE:-false}" == "true" || ! -t 0 ]]; then
                    skill_dest="2"
                else
                    while true; do
                        echo -e "Where would you like to deploy the pqc-secrets skill?"
                        echo -e "  1) Home directory (~/.agents/skills/pqc-secrets/SKILL.md)"
                        echo -e "  2) Current/Target directory ($target_dir/.agents/skills/pqc-secrets/SKILL.md)"
                        echo -ne "${BRIGHT_YELLOW}▸ ${RESET}Enter choice [1 or 2, default: 2]: "
                        local choice
                        read -r choice
                        choice=$(echo "$choice" | xargs)
                        if [[ -z "$choice" ]]; then
                            skill_dest="2"
                            break
                        elif [[ "$choice" == "1" || "$choice" == "2" ]]; then
                            skill_dest="$choice"
                            break
                        else
                            echo "Invalid choice. Please enter 1 or 2."
                        fi
                    done
                fi

                local skill_src="${REPO_DIR}/.agents/skills/pqc-secrets"
                local final_dest=""
                if [[ "$skill_dest" == "1" ]]; then
                    final_dest="$HOME/.agents/skills/pqc-secrets"
                else
                    final_dest="$target_dir/.agents/skills/pqc-secrets"
                fi

                echo -e "${BRIGHT_BLUE}Deploying pqc-secrets skill to: $final_dest${RESET}"
                mkdir -p "$final_dest"
                if cp -r "$skill_src/"* "$final_dest/" 2>/dev/null; then
                    echo -e "${BRIGHT_GREEN}✅ Deployed pqc-secrets skill to $final_dest${RESET}"
                else
                    print_error "Failed to deploy pqc-secrets skill"
                fi
            fi

            echo -e "${BRIGHT_GREEN}✅ Rules deployment complete${RESET}"
            ;;

        --agents)
            if confirm_action "Deploy AGENTS.md standard rules to: $target_dir?" "y"; then
                deploy_agents "$target_dir"
            fi
            ;;

        # Security files deployment
        --secure)
            echo -e "${BRIGHT_BLUE}Deploying Agents Security Files${RESET}"

            # Deploy AGENTS_CODE_SECURITY.md
            if confirm_action "Deploy AGENTS_CODE_SECURITY.md (code security standards)?" "y"; then
                local code_security_source="${REPO_DIR}/AGENTS_CODE_SECURITY.md"
                if [[ -f "$code_security_source" ]]; then
                     cp -f "$code_security_source" "$target_dir/AGENTS_CODE_SECURITY.md" 2>/dev/null || true
                     echo -e "${GREEN}✓ AGENTS_CODE_SECURITY.md at $target_dir${RESET}"
                else
                     echo -e "${BRIGHT_RED}Error: AGENTS_CODE_SECURITY.md not found at $code_security_source${RESET}"
                fi
            fi

            # Deploy AGENTS_LLM_SECURITY.md
            if confirm_action "Deploy AGENTS_LLM_SECURITY.md (LLM/agentic security standards)?" "y"; then
                local llm_security_source="${REPO_DIR}/AGENTS_LLM_SECURITY.md"
                if [[ -f "$llm_security_source" ]]; then
                     cp -f "$llm_security_source" "$target_dir/AGENTS_LLM_SECURITY.md" 2>/dev/null || true
                     echo -e "${GREEN}✓ AGENTS_LLM_SECURITY.md at $target_dir${RESET}"
                else
                     echo -e "${BRIGHT_RED}Error: AGENTS_LLM_SECURITY.md not found at $llm_security_source${RESET}"
                fi
            fi

            echo -e "${BRIGHT_GREEN}✅ Agents security deployment complete${RESET}"
            ;;


        # Template Agent System
        --template-agent)
            if confirm_action "Deploy template agent files to: $target_dir?" "y"; then
                deploy_template_agent "$target_dir"
            fi
            ;;

        # Utility deployments
        --critical)
            if confirm_action "Deploy critical.md (essential repository rules)?" "y"; then
                deploy_critical "$target_dir"
            fi
            ;;
        --gitignore)
            if confirm_action "Deploy/merge .gitignore configuration?" "y"; then
                deploy_gitignore "$target_dir"
            fi
            ;;
        --github-actions)
            if confirm_action "Deploy secure GitHub Actions workflow templates?" "y"; then
                deploy_github_actions "$target_dir"
            fi
            ;;
        --local-security)
            if confirm_action "Deploy local security hooks and checking scripts?" "y"; then
                deploy_local_security "$target_dir"
            fi
            ;;

        --mcp-recipes)
            if confirm_action "Deploy MCP server configuration recipes?" "y"; then
                deploy_mcp_recipes "$target_dir"
            fi
            ;;

        --unlock)
            if confirm_action "Unlock repository (deploy ref-codebases, research collections, pliny)?" "y"; then
                deploy_unlock "$target_dir"
            fi
            ;;

        --skills)
            local skills_dir="${REPO_DIR}/.agents/skills"
            if confirm_action "Deploy all available skill packs?" "y"; then
                deploy_skills "$target_dir"
            elif [[ "${AINISH_NON_INTERACTIVE:-false}" == "false" && -t 0 ]]; then
                # Interactive selection of specific skill
                local available_skills=()
                for d in "$skills_dir"/*/; do
                    if [[ -d "$d" ]]; then
                        available_skills+=($(basename "$d"))
                    fi
                done

                if [[ ${#available_skills[@]} -eq 0 ]]; then
                    echo -e "${YELLOW}No skills found in source directory.${RESET}"
                else
                    while true; do
                        echo -e "\n${BRIGHT_CYAN}Select a specific skill to deploy:${RESET}"
                        local idx=1
                        for s in "${available_skills[@]}"; do
                            printf "  ${BRIGHT_WHITE}%2d${RESET}) %s\n" "$idx" "$s"
                            ((idx++))
                        done
                        echo -e "   q) Cancel"

                        echo -ne "\n${BRIGHT_YELLOW}▸ ${RESET}Enter choice [1-${#available_skills[@]}, q=quit]: "
                        local choice
                        read -r choice
                        choice=$(echo "$choice" | xargs)

                        if [[ "$choice" == "q" || "$choice" == "Q" ]]; then
                            echo "Aborted."
                            break
                        elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#available_skills[@]} )); then
                            local chosen_skill="${available_skills[$((choice-1))]}"
                            local skill_src="$skills_dir/$chosen_skill"
                            local skill_dest="$target_dir/.agents/skills/$chosen_skill"

                            echo -e "${BRIGHT_BLUE}Deploying: $chosen_skill to $skill_dest${RESET}"
                            mkdir -p "$skill_dest"
                            if cp -r "$skill_src/"* "$skill_dest/" 2>/dev/null; then
                                echo -e "${BRIGHT_GREEN}✅ Successfully deployed $chosen_skill${RESET}"
                            else
                                print_error "Failed to deploy skill: $chosen_skill"
                            fi
                            break
                        else
                            echo "Invalid option. Please choose a number or 'q'."
                        fi
                    done
                fi
            else
                echo -e "${YELLOW}Aborted skills deployment.${RESET}"
            fi
            ;;

        --scrolls)
            if confirm_action "Deploy scrolls (knowledge databases) to: $target_dir?" "y"; then
                deploy_scrolls "$target_dir"
            fi
            ;;

        --license)
            if confirm_action "Deploy LICENSE to: $target_dir?" "y"; then
                deploy_license "$target_dir"
            fi
            ;;

        --signals)
            local deploy_examples="false"
            local real_target="$target_dir"

            # Check if "ai" argument was passed (captured as target_dir by main)
            if [[ "$target_dir" == "ai" ]]; then
                deploy_examples="true"
                # If "ai" was the first arg, check if user provided a target dir as the second arg
                if [[ -n "${2:-}" ]]; then
                    real_target="$2"
                else
                    real_target="$(pwd)"
                fi
            fi

            if confirm_action "Deploy signals monitoring framework to: $real_target?" "y"; then
                deploy_signals "$real_target" "$deploy_examples"
            fi
            ;;

        --llms-txt)
            deploy_llms_txt "$target_dir"
            ;;

        --cli)
            run_cli_interface
            ;;

        *)
            print_error "Unknown command: $command"
            echo "Use 'ainish-coder --help' for usage information" >&2
            exit 1
            ;;
    esac
}

# Parse global flags
export AINISH_NON_INTERACTIVE="false"
filtered_args=()
for arg in "$@"; do
    if [[ "$arg" == "-y" || "$arg" == "--yes" || "$arg" == "--non-interactive" ]]; then
        export AINISH_NON_INTERACTIVE="true"
    else
        filtered_args+=("$arg")
    fi
done

if [[ ${#filtered_args[@]} -gt 0 ]]; then
    set -- "${filtered_args[@]}"
fi

# Check if at least one argument provided
if [[ $# -eq 0 ]]; then
    print_error "No command specified"
    echo "Use 'ainish-coder --help' for usage information" >&2
    echo "Use 'ainish-coder --cli' for the interactive menu" >&2
    exit 1
fi

# Run main function
main "$@"
