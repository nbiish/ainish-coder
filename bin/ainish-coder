#!/bin/bash
# Main ainish-coder CLI tool
# Comprehensive configuration manager for AI coding assistants

set -euo pipefail

# Ensure we have a minimal PATH for basic commands
# This prevents issues if PATH is corrupted in the calling environment
if [[ ":$PATH:" != *":/usr/bin:"* ]] || [[ ":$PATH:" != *":/bin:"* ]]; then
    export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
fi

# Get script directory, resolving symlinks if necessary
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
SRC_DIR="${SCRIPT_DIR}/../src"

# Load quanta (core utilities)
source "${SRC_DIR}/quanta/colors.sh"
source "${SRC_DIR}/quanta/paths.sh"
source "${SRC_DIR}/quanta/file_operations.sh"
source "${SRC_DIR}/quanta/validation.sh"
source "${SRC_DIR}/quanta/backup.sh"
source "${SRC_DIR}/quanta/ignore_patterns.sh"

# Load atoms (deployment functions)
source "${SRC_DIR}/atoms/help.sh"
source "${SRC_DIR}/atoms/deploy_commands.sh"
source "${SRC_DIR}/atoms/deploy_agents.sh"

source "${SRC_DIR}/atoms/deploy_critical.sh"
source "${SRC_DIR}/atoms/deploy_gitignore.sh"
# Load ignore file deployment atoms
source "${SRC_DIR}/atoms/deploy_github_actions.sh"
source "${SRC_DIR}/atoms/deploy_local_security.sh"
source "${SRC_DIR}/atoms/deploy_template_agent.sh"
source "${SRC_DIR}/atoms/deploy_skills.sh"
source "${SRC_DIR}/atoms/deploy_unlock.sh"
source "${SRC_DIR}/atoms/deploy_mcp_recipes.sh"
source "${SRC_DIR}/atoms/deploy_scrolls.sh"
source "${SRC_DIR}/atoms/deploy_license.sh"
source "${SRC_DIR}/atoms/deploy_signals.sh"
source "${SRC_DIR}/atoms/deploy_llms_txt.sh"

# Main function
main() {
    local command="$1"
    shift

    # Get target directory (default to current directory)
    local target_dir="${1:-$(pwd)}"

    # Prompt user for deploy destination base (home vs target dir)
    # Echoes "$HOME" or "$target_dir" to stdout
    _pick_dest_base() {
        # If non-interactive mode OR not in interactive mode, default to target_dir
        if [[ "${AINISH_NON_INTERACTIVE:-false}" == "true" ]] || [[ "${AINISH_INTERACTIVE:-false}" != "true" ]] || [[ ! -t 0 ]]; then
            echo "$target_dir"
            return
        fi

        while true; do
            echo -e "Where would you like to deploy?" >&2
            echo -e "  1) Home directory (~)/" >&2
            echo -e "  2) Current/Target directory ($target_dir)" >&2
            echo -ne "${BRIGHT_YELLOW}▸ ${RESET}Enter choice [1 or 2, default: 2]: " >&2
            local choice
            read -r choice || true
            choice=$(echo "$choice" | xargs)
            if [[ -z "$choice" ]]; then
                echo "$target_dir"
                return
            elif [[ "$choice" == "1" ]]; then
                echo "$HOME"
                return
            elif [[ "$choice" == "2" ]]; then
                echo "$target_dir"
                return
            else
                echo "Invalid choice. Please enter 1 or 2." >&2
            fi
        done
    }

    # Ask if user wants to symlink from repo source (single source of truth).
    # Returns 0 if symlink, 1 if copy. Respects global -l flag.
    # Defaults to copy (n) — safer, avoids accidental source modification.
    _confirm_symlink() {
        if [[ "${AINISH_LINK_MODE:-false}" == "true" ]]; then
            return 0  # Already set globally via -l
        fi
        # If non-interactive mode OR not in interactive mode, default to copy (safer)
        if [[ "${AINISH_NON_INTERACTIVE:-false}" == "true" ]] || [[ "${AINISH_INTERACTIVE:-false}" != "true" ]] || [[ ! -t 0 ]]; then
            return 1  # Default to copy (safer default)
        fi
        confirm_action "Symlink from repo source (single source of truth)?" "n"
    }

    # Run a deploy function, optionally overriding AINISH_LINK_MODE for just
    # this call based on user preference. Pass the deploy command + args.
    _with_link_choice() {
        if _confirm_symlink; then
            AINISH_LINK_MODE="true" "$@"
        else
            AINISH_LINK_MODE="false" "$@"
        fi
    }

    case "$command" in
        --help|-h)
            show_help
            ;;
        --version|-v)
            show_version
            ;;

        # Commands deployment
        --commands)
            if [[ $# -eq 0 ]]; then
                print_error "Missing argument for --commands"
                echo "Usage: ainish-coder --commands {tool}" >&2
                echo "Example: ainish-coder --commands cursor" >&2
                exit 1
            fi
            deploy_commands "$1"
            ;;



        # Core rules deployment
        --rules)
            _TRACK_DETAIL="AGENTS.md+gitignore"
            echo -e "${BRIGHT_BLUE}Deploying Rules System${RESET}"

            if confirm_action "Deploy AGENTS.md standard rules?" "y"; then
                local rules_agents_dest="$(_pick_dest_base)"
                _with_link_choice deploy_agents "$rules_agents_dest"
            fi

            # Ensure global AGENTS.md symlinks are always correct
            deploy_agents_global

            if confirm_action "Deploy/merge .gitignore configuration to: $target_dir?" "y"; then
                _with_link_choice deploy_gitignore "$target_dir"
            fi

            if confirm_action "Deploy PQC security skills (pqc-secrets + pqc-signatures-security)?" "y"; then
                local pqc_dest_base="$(_pick_dest_base)"
                local pqc_use_link="false"
                if _confirm_symlink; then
                    pqc_use_link="true"
                fi

                _deploy_one_pqc() {
                    local skill_name="$1" skill_label="$2"
                    local skill_src="${REPO_DIR}/.agents/skills/${skill_name}"
                    local final_dest="$pqc_dest_base/.agents/skills/${skill_name}"
                    echo -e "${BRIGHT_BLUE}Deploying ${skill_label} to: $final_dest${RESET}"
                    if [[ "$pqc_use_link" == "true" ]]; then
                        AINISH_LINK_MODE="true" deploy_path_contents "$skill_src" "$final_dest"
                    else
                        AINISH_LINK_MODE="false" deploy_path_contents "$skill_src" "$final_dest"
                    fi
                }

                if _deploy_one_pqc "pqc-secrets" "pqc-secrets (PQC Secrets Management)"; then
                    echo -e "${BRIGHT_GREEN}✅ Deployed pqc-secrets${RESET}"
                else
                    print_error "Failed to deploy pqc-secrets"
                fi
                if _deploy_one_pqc "pqc-signatures-security" "pqc-signatures-security (PQC Signatures & Integrity)"; then
                    echo -e "${BRIGHT_GREEN}✅ Deployed pqc-signatures-security${RESET}"
                else
                    print_error "Failed to deploy pqc-signatures-security"
                fi
                _TRACK_DETAIL="${_TRACK_DETAIL}+pqc-secrets+pqc-signatures"
            fi

            echo -e "${BRIGHT_GREEN}✅ Rules deployment complete${RESET}"
            ;;

        --agents)
            _TRACK_DETAIL="AGENTS.md"
            if confirm_action "Deploy AGENTS.md standard rules?" "y"; then
                local agents_dest="$(_pick_dest_base)"
                _with_link_choice deploy_agents "$agents_dest"
            fi

            # Ensure global AGENTS.md symlinks are always correct
            deploy_agents_global
            ;;

        # Security files deployment
        --secure)
            _TRACK_DETAIL="AGENTS_CODE+LLM_SECURITY"
            echo -e "${BRIGHT_BLUE}Deploying Agents Security Files${RESET}"

            if confirm_action "Deploy AGENTS_CODE_SECURITY.md (code security standards)?" "y"; then
                local code_security_source="${REPO_DIR}/AGENTS_CODE_SECURITY.md"
                if [[ -f "$code_security_source" ]]; then
                     _with_link_choice deploy_path "$code_security_source" "$target_dir/AGENTS_CODE_SECURITY.md"
                     echo -e "${GREEN}✓ AGENTS_CODE_SECURITY.md at $target_dir${RESET}"
                else
                     echo -e "${BRIGHT_RED}Error: AGENTS_CODE_SECURITY.md not found at $code_security_source${RESET}"
                fi
            fi

            if confirm_action "Deploy AGENTS_LLM_SECURITY.md (LLM/agentic security standards)?" "y"; then
                local llm_security_source="${REPO_DIR}/AGENTS_LLM_SECURITY.md"
                if [[ -f "$llm_security_source" ]]; then
                     _with_link_choice deploy_path "$llm_security_source" "$target_dir/AGENTS_LLM_SECURITY.md"
                     echo -e "${GREEN}✓ AGENTS_LLM_SECURITY.md at $target_dir${RESET}"
                else
                     echo -e "${BRIGHT_RED}Error: AGENTS_LLM_SECURITY.md not found at $llm_security_source${RESET}"
                fi
            fi

            echo -e "${BRIGHT_GREEN}✅ Agents security deployment complete${RESET}"
            ;;


        # Template Agent System
        --template-agent)
            _TRACK_DETAIL="template-agent"
            if confirm_action "Deploy template agent files to: $target_dir?" "y"; then
                _with_link_choice deploy_template_agent "$target_dir"
            fi
            ;;

        # Utility deployments
        --critical)
            _TRACK_DETAIL="critical.md"
            if confirm_action "Deploy critical.md (essential repository rules)?" "y"; then
                _with_link_choice deploy_critical "$target_dir"
            fi
            ;;
        --gitignore)
            _TRACK_DETAIL="gitignore"
            if confirm_action "Deploy/merge .gitignore configuration?" "y"; then
                _with_link_choice deploy_gitignore "$target_dir"
            fi
            ;;
        --github-actions)
            _TRACK_DETAIL="github-actions"
            if confirm_action "Deploy secure GitHub Actions workflow templates?" "y"; then
                _with_link_choice deploy_github_actions "$target_dir"
            fi
            ;;
        --local-security)
            _TRACK_DETAIL="local-security"
            if confirm_action "Deploy local security hooks and checking scripts?" "y"; then
                _with_link_choice deploy_local_security "$target_dir"
            fi
            ;;

        --mcp-recipes)
            _TRACK_DETAIL="mcp-recipes"
            if confirm_action "Deploy MCP server configuration recipes?" "y"; then
                _with_link_choice deploy_mcp_recipes "$target_dir"
            fi
            ;;

        --unlock)
            _TRACK_DETAIL="pliny-unlock"
            if confirm_action "Unlock repository (deploy ref-codebases, research collections, pliny)?" "y"; then
                local unlock_dest="$(_pick_dest_base)"
                _with_link_choice deploy_unlock "$unlock_dest"
            fi
            ;;

        --skills)
            local skills_dir="${REPO_DIR}/.agents/skills"
            if confirm_action "Deploy all available skill packs?" "y"; then
                local skills_dest="$(_pick_dest_base)"
                _with_link_choice deploy_skills "$skills_dest"
                _TRACK_DETAIL="all-skills"
            elif [[ "${AINISH_INTERACTIVE:-false}" == "true" && -t 0 ]]; then
                # Interactive selection of specific skill
                local available_skills=()
                for d in "$skills_dir"/*/; do
                    if [[ -d "$d" ]]; then
                        available_skills+=($(basename "$d"))
                    fi
                done

                if [[ ${#available_skills[@]} -eq 0 ]]; then
                    echo -e "${YELLOW}No skills found in source directory.${RESET}"
                    _TRACK_DETAIL="none-available"
                else
                    while true; do
                        echo -e "\n${BRIGHT_CYAN}Select a specific skill to deploy:${RESET}"
                        local idx=1
                        for s in "${available_skills[@]}"; do
                            printf "  ${BRIGHT_WHITE}%2d${RESET}) %s\n" "$idx" "$s"
                            ((idx++))
                        done
                        echo -e "   q) Cancel"

                        echo -ne "\n${BRIGHT_YELLOW}▸ ${RESET}Enter choice [1-${#available_skills[@]}, q=quit]: "
                        local choice
                        read -r choice || true
                        choice=$(echo "$choice" | xargs)

                        if [[ "$choice" == "q" || "$choice" == "Q" ]]; then
                            echo "Aborted."
                            _TRACK_DETAIL="cancelled"
                            break
                        elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#available_skills[@]} )); then
                            local chosen_skill="${available_skills[$((choice-1))]}"
                            local skill_dest_base="$(_pick_dest_base)"
                            local skill_src="$skills_dir/$chosen_skill"
                            local skill_dest="$skill_dest_base/.agents/skills/$chosen_skill"

                            echo -e "${BRIGHT_BLUE}Deploying: $chosen_skill to $skill_dest${RESET}"
                            mkdir -p "$skill_dest"
                            if _with_link_choice deploy_path_contents "$skill_src" "$skill_dest"; then
                                echo -e "${BRIGHT_GREEN}✅ Successfully deployed $chosen_skill${RESET}"
                                _TRACK_DETAIL="skill:${chosen_skill}"
                            else
                                print_error "Failed to deploy skill: $chosen_skill"
                                _TRACK_DETAIL="skill-failed:${chosen_skill}"
                            fi
                            break
                        else
                            echo "Invalid option. Please choose a number or 'q'."
                        fi
                    done
                fi
            else
                echo -e "${YELLOW}Aborted skills deployment.${RESET}"
                _TRACK_DETAIL="aborted-noninteractive"
            fi
            ;;

        --scrolls)
            _TRACK_DETAIL="scrolls"
            if confirm_action "Deploy scrolls (knowledge databases) to: $target_dir?" "y"; then
                _with_link_choice deploy_scrolls "$target_dir"
            fi
            ;;

        --license)
            _TRACK_DETAIL="LICENSE"
            if confirm_action "Deploy LICENSE to: $target_dir?" "y"; then
                _with_link_choice deploy_license "$target_dir"
            fi
            ;;

        --signals)
            _TRACK_DETAIL="signals"
            local deploy_examples="false"
            local real_target="$target_dir"

            # Check if "ai" argument was passed (captured as target_dir by main)
            if [[ "$target_dir" == "ai" ]]; then
                deploy_examples="true"
                # If "ai" was the first arg, check if user provided a target dir as the second arg
                if [[ -n "${2:-}" ]]; then
                    real_target="$2"
                else
                    real_target="$(pwd)"
                fi
            fi

            if confirm_action "Deploy signals monitoring framework to: $real_target?" "y"; then
                _with_link_choice deploy_signals "$real_target" "$deploy_examples"
            fi
            ;;

        --llms-txt)
            _TRACK_DETAIL="llms.txt"
            local llms_dest="$target_dir"
            if [[ "${AINISH_INTERACTIVE:-false}" == "true" && -t 0 ]]; then
                if confirm_action "Deploy llms.txt file?" "y"; then
                    llms_dest="$(_pick_dest_base)"
                    _with_link_choice deploy_llms_txt "$llms_dest"
                fi
            else
                _with_link_choice deploy_llms_txt "$llms_dest"
            fi
            ;;

        *)
            print_error "Unknown command: $command"
            echo "Use 'ainish-coder --help' for usage information" >&2
            exit 1
            ;;
    esac
}

# Parse global flags
export AINISH_NON_INTERACTIVE="false"
export AINISH_INTERACTIVE="false"
export AINISH_LINK_MODE="false"
export AINISH_NO_OVERWRITE="false"
filtered_args=()
for arg in "$@"; do
    if [[ "$arg" == "-y" || "$arg" == "--yes" || "$arg" == "--non-interactive" ]]; then
        export AINISH_NON_INTERACTIVE="true"
    elif [[ "$arg" == "-i" || "$arg" == "--interactive" ]]; then
        export AINISH_INTERACTIVE="true"
    elif [[ "$arg" == "-l" || "$arg" == "--link" ]]; then
        export AINISH_LINK_MODE="true"
    elif [[ "$arg" == "-n" || "$arg" == "--no-overwrite" ]]; then
        export AINISH_NO_OVERWRITE="true"
    else
        filtered_args+=("$arg")
    fi
done

if [[ ${#filtered_args[@]} -gt 0 ]]; then
    set -- "${filtered_args[@]}"
fi

# ── Usage tracking (EXIT trap) ────────────────────────────────────────────────
# Logs the ainish-coder invocation to ~/.cache/ainish-coder/usage.csv on exit.
# _TRACK_DETAIL is set by individual handlers (e.g. --skills) to capture the
# specific skill or agent that was deployed, giving granular per-operation data.
_TRACK_DETAIL=""
if [[ "${AINISH_NO_TRACKING:-false}" != "true" ]]; then
  _TRACK_START=$(python3 -c "import time; print(int(time.time()*1000))" 2>/dev/null || echo 0)
  _track_on_exit() {
    local rc=$?
    local now
    now=$(python3 -c "import time; print(int(time.time()*1000))" 2>/dev/null || echo 0)
    local tracker_bin
    tracker_bin="$(command -v cmd-tracker 2>/dev/null || true)"
    if [[ -n "$tracker_bin" && -x "$tracker_bin" ]]; then
      local subcmd="${1:-}"
      local detail="${_TRACK_DETAIL:-}"
      "$tracker_bin" "ainish-coder" "${subcmd}${detail:+,${detail}}" "" -- true 2>/dev/null || true
    fi
    exit $rc
  }
  trap '_track_on_exit "${1:-}"' EXIT
  # Save the first arg (subcommand) before main shifts it
  _TRACK_SUBCMD="${1:-}"
fi

# Check if at least one argument provided
if [[ $# -eq 0 ]]; then
    print_error "No command specified"
    echo "Use 'ainish-coder --help' for usage information" >&2
    exit 1
fi

# Run main function
main "$@"
