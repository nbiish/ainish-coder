#!/usr/bin/env bash
# pi provider-switching wrapper
# Usage: pi <provider> [args...]  — hot-swaps pi config to use provider, then runs pi
#        pi [args...]             — passthrough to real pi binary
set -euo pipefail

LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)"
source "${LIB_DIR}/providers.sh"
source "${LIB_DIR}/hot_swap.sh"

# Resolve the real pi binary (skip this wrapper via PATH manipulation)
_real_pi() {
  local self
  self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local old_path="$PATH"
  PATH="$(echo "$PATH" | tr ':' '\n' | grep -v "^${self}$" | tr '\n' ':')"
  local bin
  bin="$(command -v pi 2>/dev/null || true)"
  PATH="$old_path"
  if [[ -z "$bin" ]]; then
    echo "error: real pi binary not found on PATH" >&2
    exit 1
  fi
  echo "$bin"
}

REAL_PI="$(_real_pi)"

provider="${1:-}"

if provider_has "$provider"; then
  shift
  hot_swap_pi "$provider"
  # Do NOT use exec — the EXIT trap must fire to restore the original config
  "$REAL_PI" "$@"
  exit $?
else
  exec "$REAL_PI" "$@"
fi
