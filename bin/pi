#!/usr/bin/env bash
# pi wrapper — MCP sub-agent support only; pass-through args to real pi-coding-agent.
# Provider configs: run `prepend <provider>` first (file symlink), then invoke pi normally.
#
# Usage:
#   prepend zenmux
#   pi [--mcp server1,server2] [--mcp-all] [--no-mcp] [pi args...]
set -euo pipefail

LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)"
source "${LIB_DIR}/mcp_settings.sh"
source "${LIB_DIR}/tracker.sh"
source "${LIB_DIR}/resolve_binary.sh"

export MCP_STATE_FILE="$(mktemp /tmp/ainish-mcp-state.XXXXXX)"

_parsed=()
while IFS= read -r line; do
  _parsed+=("$line")
done < <(mcp_parse_flags "$@")
if [[ ${#_parsed[@]} -gt 0 ]]; then
  set -- "${_parsed[@]}"
fi
unset _parsed

source "${MCP_STATE_FILE}"
rm -f "${MCP_STATE_FILE}"

REAL_PI="$(resolve_real_binary pi "${BASH_SOURCE[0]}")"

MCP_CLEANUP_NEEDED="false"
mcp_ext_file=""

if [[ "$MCP_ENABLED" == "true" ]]; then
  mcp_load
  mcp_ext_file="$(mcp_generate_pi_extension "pi")"
fi

if [[ -n "$mcp_ext_file" && -f "$mcp_ext_file" ]]; then
  run_with_tracker "pi" "" "" -- "$REAL_PI" --extension "$mcp_ext_file" "$@"
else
  run_with_tracker "pi" "" "" -- "$REAL_PI" "$@"
fi
rc=$?
if [[ "$MCP_CLEANUP_NEEDED" == "true" && -n "$mcp_ext_file" ]]; then
  rm -f "$mcp_ext_file"
fi
exit $rc
