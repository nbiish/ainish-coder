#!/usr/bin/env bash
# whalecode provider-switching wrapper
# Usage: whalecode [args...]  — passthrough to real codewhale binary
set -euo pipefail

# Resolve the real codewhale binary
_real_codewhale() {
  local self
  self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local old_path="$PATH"
  PATH="$(echo "$PATH" | tr ':' '\n' | grep -v "^${self}$" | tr '\n' ':')"
  local bin
  bin="$(command -v codewhale 2>/dev/null || true)"
  PATH="$old_path"
  if [[ -z "$bin" ]]; then
    echo "error: real codewhale binary not found on PATH" >&2
    exit 1
  fi
  echo "$bin"
}

REAL_CODEWHALE="$(_real_codewhale)"

exec "$REAL_CODEWHALE" "$@"
