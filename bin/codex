#!/usr/bin/env bash
# codex provider-switching wrapper
# Usage: codex <provider> [args...]  — hot-swaps codex config to use provider, then runs codex
#        codex [args...]             — passthrough to real codex binary
set -euo pipefail

LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)"
source "${LIB_DIR}/providers.sh"
source "${LIB_DIR}/hot_swap.sh"

# Resolve the real codex binary (skip this wrapper)
_real_codex() {
  local self
  self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local old_path="$PATH"
  PATH="$(echo "$PATH" | tr ':' '\n' | grep -v "^${self}$" | tr '\n' ':')"
  local bin
  bin="$(command -v codex 2>/dev/null || true)"
  PATH="$old_path"
  if [[ -z "$bin" ]]; then
    echo "error: real codex binary not found on PATH" >&2
    exit 1
  fi
  echo "$bin"
}

REAL_CODEX="$(_real_codex)"

provider="${1:-}"

if provider_has "$provider"; then
  shift
  if provider_supports "$provider" "codex"; then
    hot_swap_codex "$provider"
    # Do NOT use exec — the EXIT trap must fire to restore the original config
    "$REAL_CODEX" "$@"
    exit $?
  else
    echo "error: ${provider} does not support codex (missing /responses endpoint)" >&2
    exit 1
  fi
else
  exec "$REAL_CODEX" "$@"
fi
