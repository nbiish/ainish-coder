#!/usr/bin/env bash
# mini wrapper — MCP sub-agent support only; pass-through args to real mini-swe-agent.
# Provider configs: run `prepend <provider>` first (file symlink), then invoke mini normally.
#
# Usage:
#   prepend zenmux
#   mini [--mcp server1,server2] [--mcp-all] [--no-mcp] [mini args...]
set -euo pipefail

LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)"
source "${LIB_DIR}/mcp_settings.sh"
source "${LIB_DIR}/tracker.sh"
source "${LIB_DIR}/resolve_binary.sh"

export MCP_STATE_FILE="$(mktemp /tmp/ainish-mcp-state.XXXXXX)"

_parsed=()
while IFS= read -r line; do
  _parsed+=("$line")
done < <(mcp_parse_flags "$@")
if [[ ${#_parsed[@]} -gt 0 ]]; then
  set -- "${_parsed[@]}"
fi
unset _parsed

source "${MCP_STATE_FILE}"
rm -f "${MCP_STATE_FILE}"

REAL_MINI="$(resolve_real_binary mini "${BASH_SOURCE[0]}")"

if [[ "$MCP_ENABLED" == "true" ]]; then
  mcp_load
  eval "$(mcp_generate_mini_env "mini")"
fi

run_with_tracker "mini" "" "" -- "$REAL_MINI" "$@"
exit $?
